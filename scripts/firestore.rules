rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados pueden leer/escribir
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    // Ejemplo: Solo admins pueden escribir en configuración
    match /configuration/{doc} {
      allow write: if request.auth.token.role in ['SUPER_ADMIN', 'ADMIN'];
      allow read: if request.auth != null;
    }
    // Ejemplo: Solo el dueño puede leer su driver
    match /drivers/{driverId} {
      allow read, write: if request.auth.uid == driverId;
    }
  }
}
